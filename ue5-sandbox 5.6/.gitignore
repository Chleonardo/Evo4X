# ============================================================
# Unreal Engine 5 — generated build artifacts (DO NOT COMMIT)
# ============================================================

# Compiled binaries (rebuilt by UBT automatically)
Binaries/

# Build intermediates — largest folder, ~2GB, fully regenerated
Intermediate/

# Editor saved state, logs, crash reports, backups
Saved/

# Shader/material derived data cache (regenerated on first launch)
DerivedDataCache/

# Visual Studio solution — regenerated by UBT ("Generate Visual Studio project files")
*.sln
.vs/

# ============================================================
# KEEP (do not add these):
# Source/        — all C++ code
# Content/       — .uasset files (M_HexMap, SandboxMap, etc.)
# Config/        — DefaultEngine.ini, DefaultGame.ini, etc.
# *.uproject     — project descriptor
# ============================================================
